{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "99"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Edit(~/.claude/**)",
      "Read",
      "Write(~/.claude/**)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(diff:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(pwd:*)",
      "Bash(echo:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",
      "Bash(tee:*)",
      "Bash(uname:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(test:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\check-setup.ps1\"'"
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\clear-markers.ps1\"'"
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\check-config-updates.ps1\"'"
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\check-state.ps1\"'"
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\bin\\ways\" init'"
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\bin\\ways\" corpus --if-stale --quiet'"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\clear-markers.ps1\"'"
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\check-state.ps1\"'"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\check-state.ps1\"'"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\clear-markers.ps1\"'"
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\check-state.ps1\"'"
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\bin\\ways\" init'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\check-file-pre.ps1\"'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\check-bash-pre.ps1\"'"
          }
        ]
      },
      {
        "matcher": "TaskCreate",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\mark-tasks-active.ps1\"'"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\check-task-pre.ps1\"'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\check-prompt.ps1\"'"
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\check-state.ps1\"'"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\inject-subagent.ps1\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\hooks\\ways\\win\\check-response.ps1\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command '& \"$env:USERPROFILE\\.claude\\statusline.ps1\"'"
  },
  "alwaysThinkingEnabled": true
}
